---
import { Image } from 'astro:assets';
import type { MediaItem } from '../lib/media';

interface Props {
  items: MediaItem[];
  alt: string;
}

const { items, alt } = Astro.props;
---

<div class="photo-carousel" data-photo-carousel>
  <div class="photo-carousel-viewport" data-lightbox-group>
    {
      items.map((item, i) =>
        item.kind === 'image' ? (
          <Image
            src={item.src}
            alt={`${alt} — photo ${i + 1} of ${items.length}`}
            widths={[400, 800, 1200]}
            sizes="(min-width: 48rem) 40rem, 100vw"
            class="photo-carousel-slide"
            data-index={i}
            data-lightbox
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        ) : (
          <video
            src={item.src}
            aria-label={`${alt} — video ${i + 1} of ${items.length}`}
            class="photo-carousel-slide"
            data-index={i}
            data-lightbox
            controls
            playsinline
            preload="metadata"
          />
        ),
      )
    }
  </div>
  <button type="button" class="photo-carousel-nav photo-carousel-prev" aria-label="Previous photo">
    ‹
  </button>
  <button type="button" class="photo-carousel-nav photo-carousel-next" aria-label="Next photo">
    ›
  </button>
  <p class="photo-carousel-count" aria-hidden="true">
    <span data-current>1</span> / {items.length}
  </p>
</div>

<script>
  function setUpCarousel(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.photo-carousel-slide'));
    const counter = root.querySelector('[data-current]');
    let current = 0;

    function show(index: number) {
      current = (index + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === current);
        if (slide instanceof HTMLVideoElement && i !== current) slide.pause();
      });
      if (counter) counter.textContent = String(current + 1);
    }

    root.querySelector('.photo-carousel-prev')?.addEventListener('click', () => show(current - 1));
    root.querySelector('.photo-carousel-next')?.addEventListener('click', () => show(current + 1));

    show(0);
  }

  document
    .querySelectorAll<HTMLElement>('[data-photo-carousel]')
    .forEach(setUpCarousel);
</script>

<style>
  .photo-carousel {
    position: relative;
    margin: 1rem 0;
    overflow: hidden;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .photo-carousel-viewport {
    position: relative;
    aspect-ratio: 4 / 3;
  }

  .photo-carousel-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease;
    cursor: zoom-in;
  }

  /* Videos play inline via their own controls, they don't open the lightbox */
  video.photo-carousel-slide {
    cursor: default;
    object-fit: contain;
    background: #000;
  }

  .photo-carousel-slide.is-active {
    opacity: 1;
    visibility: visible;
  }

  .photo-carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    border: 1px solid #fff;
    background: #000;
    color: #fff;
    width: 2.25rem;
    height: 2.25rem;
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-carousel-nav:hover {
    background: #333;
  }

  .photo-carousel-prev {
    left: 0.5rem;
  }

  .photo-carousel-next {
    right: 0.5rem;
  }

  .photo-carousel-count {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    margin: 0;
    padding: 0.15rem 0.5rem;
    background: #000;
    color: #fff;
    font-size: 0.75rem;
  }
</style>
