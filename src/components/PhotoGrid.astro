---
import { Image } from 'astro:assets';
import type { MediaItem } from '../lib/media';

interface Props {
  items: MediaItem[];
  alt: string;
}

const { items, alt } = Astro.props;
---

<div class="photo-grid" data-lightbox-group>
  {
    items.map((item, i) =>
      item.kind === 'image' ? (
        <Image
          src={item.src}
          alt={`${alt} — photo ${i + 1} of ${items.length}`}
          widths={[300, 600]}
          sizes="(min-width: 48rem) 20rem, 45vw"
          loading="lazy"
          data-lightbox
        />
      ) : (
        <video
          src={item.src}
          aria-label={`${alt} — video ${i + 1} of ${items.length}`}
          controls
          playsinline
          preload="metadata"
          data-lightbox
        />
      ),
    )
  }
</div>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .photo-grid img,
  .photo-grid video {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border: 1px solid var(--line);
    cursor: zoom-in;
  }

  .photo-grid video {
    cursor: default;
    object-fit: contain;
    background: #000;
  }

  @media (min-width: 30rem) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
