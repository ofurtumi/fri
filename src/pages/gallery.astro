---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts'))
  .filter((post) => post.data.photos && post.data.photos.length > 0)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const shots = posts.flatMap((post) =>
  post.data.photos!.map((photo) => ({ photo, post })),
);
---

<Base
  title="Gallery — Iceland by Camper"
  description="Every photo from the trip, in order, with where and when it was taken."
>
  <header class="site-header wrap">
    <h1>Gallery</h1>
    <p>All the photos from the road, newest first.</p>
    <p><a href="/">← back to the map</a></p>
  </header>

  <main class="gallery-wrap">
    <div class="photo-masonry">
      {
        shots.map(({ photo, post }) => {
          const { title, date, location } = post.data;
          const dateLabel = date.toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'long',
          });
          return (
            <a class="masonry-item" href={`/posts/${post.id}/`}>
              <Image
                src={photo}
                alt={`${title}, ${location}`}
                widths={[300, 600, 900]}
                sizes="(min-width: 64rem) 300px, (min-width: 48rem) 33vw, 50vw"
              />
              <span class="masonry-caption">
                {dateLabel} · {location}
              </span>
            </a>
          );
        })
      }
    </div>
    {
      shots.length === 0 && (
        <p class="gallery-empty">No photos yet — they'll show up here once posts have some.</p>
      )
    }
  </main>

  <footer class="site-footer wrap">
    <p>Written from the road, published whenever there's signal.</p>
  </footer>
</Base>
