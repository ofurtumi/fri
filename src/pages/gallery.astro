---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { mediaFor } from '../lib/media';

// The gallery is deliberately trip-agnostic: every post's media, newest first
const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const shots = posts.flatMap((post) =>
  mediaFor(post).map((item) => ({ item, post })),
);
---

<Base
  title="Myndir — Yfir Ísland"
  description="Allar myndir í þeirri röð sem þær komu inn."
>

  <main class="gallery-wrap">
    <div class="photo-masonry" data-lightbox-group>
      {
        shots.map(({ item, post }) => {
          const { title, date, location } = post.data;
          const dateLabel = date.toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'long',
          });
          return item.kind === 'image' ? (
            <a class="masonry-item" href={`/posts/${post.id}/`}>
              <Image
                src={item.src}
                alt={`${title}, ${location}`}
                widths={[300, 600, 900]}
                sizes="(min-width: 64rem) 300px, (min-width: 48rem) 33vw, 50vw"
                data-lightbox
                data-caption={`${dateLabel} · ${location}`}
              />
              <span class="masonry-caption">
                {dateLabel} · {location}
              </span>
            </a>
          ) : (
            <div class="masonry-item">
              {/* videos play in place; wrapping them in the post link would fight the controls */}
              <video
                src={item.src}
                aria-label={`${title}, ${location}`}
                controls
                playsinline
                preload="metadata"
                data-lightbox
                data-caption={`${dateLabel} · ${location}`}
              />
              <a class="masonry-caption" href={`/posts/${post.id}/`}>
                {dateLabel} · {location}
              </a>
            </div>
          );
        })
      }
    </div>
    {
      shots.length === 0 && (
        <p class="gallery-empty">No photos yet — they'll show up here once posts have some.</p>
      )
    }
  </main>
</Base>
